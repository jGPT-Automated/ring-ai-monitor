# Ring
RING_REFRESH_TOKEN=           # run: npx ring-auth-cli to get this

# Supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_anon_key

# Anthropic
ANTHROPIC_API_KEY=your_key

# Telegram
TELEGRAM_TOKEN=your_bot_token
